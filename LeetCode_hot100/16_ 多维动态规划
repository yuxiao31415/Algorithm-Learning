## 93.最长回文子串   
```java
// 中心扩散法
class Solution {
    public String longestPalindrome(String s) {
        if (s == null || s.length() < 1) return "";
        int start=0;
        int end =0;
        for(int i =0;i<s.length();i++){
            int len1 = centerExplain(s,i,i);
            int len2 = centerExplain(s,i,i+1);
            int len = Math.max(len1,len2);
            if(len>end-start+1){
                start = i -(len-1)/2;// 奇数: start = i-(len-1)/2;偶数;start = i -(len -1)/2;
                end = i+len/2;    // 奇数: end = i+(len-1)/2=i+len/2  偶数:end = i+1+(len-1)/2=i+(len+1)/2=i+len/2
            }
        }
        return s.substring(start,end+1);

    }
    public int centerExplain(String s,int left, int right){
        while(left>=0 && right<s.length() && s.charAt(left)==s.charAt(right)){
                left--;
                right++;
        }      
        return right-left - 1;// ***************
    }

}
```
